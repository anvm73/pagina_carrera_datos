# Runtime
APP_ENV=production
TRUSTED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ORIGINS=http://localhost:4321,http://localhost:8080
MAX_UPLOAD_SIZE_MB=12
MAX_REQUEST_SIZE_MB=20
OUTBOUND_REQUEST_TIMEOUT_S=12
ALLOWED_REMOTE_IMAGE_HOSTS=media.licdn.com,media-exp1.licdn.com,media-exp2.licdn.com,static.licdn.com,linkedin.com,www.linkedin.com
DATABASE_CONNECT_RETRIES=20
DATABASE_CONNECT_RETRY_DELAY_S=2

# Database
# Si DATABASE_URL no esta definida, el backend construira la conexion con POSTGRES_*.
# Para desarrollo tambien puede usar SQLite automaticamente.
# DATABASE_URL=postgresql+psycopg2://ce_iccd:CAMBIA_PASSWORD@postgres:5432/ce_iccd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ce_iccd
POSTGRES_USER=ce_iccd
POSTGRES_PASSWORD=CAMBIA_PASSWORD_POSTGRES

# Ollama
OLLAMA_URL=http://localhost:11434
CHAT_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_S=240

# Admin
ADMIN_EMAIL=ce.iccd@utem.cl
ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE
ADMIN_TOKEN_SECRET=CAMBIA_ESTE_SECRETO_ADMIN
ADMIN_TOKEN_TTL_S=86400

# Student accounts
STUDENT_TOKEN_SECRET=CAMBIA_ESTE_SECRETO_ESTUDIANTES
STUDENT_TOKEN_TTL_S=2592000
STUDENT_PASSWORD_ITERATIONS=260000
