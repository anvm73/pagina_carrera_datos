---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/global.css';
---

<MainLayout>
  <div class="space-y-8 animate-fade-in">
    
    <!-- Header con gradiente -->
    <header class="relative overflow-hidden rounded-2xl border border-utem-gray/50 bg-gradient-utem p-8 md:p-10 shadow-glow">
      <div class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-utem-purple/20 blur-3xl"></div>
      
      <div class="relative z-10 space-y-4">
        <div class="inline-flex items-center gap-3">
          <div class="h-2 w-8 rounded-full bg-white/60"></div>
          <p class="text-sm font-bold uppercase tracking-wider text-white/90">Contacto</p>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white">
          Conecta con el CE ICCD
        </h1>
        <p class="text-xl text-white/90 max-w-2xl">
          Canales directos para estudiantes, postulantes y aliados de la comunidad de Ciencia de Datos UTEM.
        </p>
      </div>
    </header>

    <!-- Tarjetas de contacto -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      
      <!-- Correo -->
      <div class="group relative rounded-xl border border-utem-gray/50 bg-gradient-card p-6 shadow-subtle hover:shadow-glow hover:border-utem-blue/30 transition-all duration-300 overflow-hidden">
        <div class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-utem-blue/10 blur-xl group-hover:scale-150 transition-transform duration-500"></div>
        
        <div class="mb-6">
          <div class="h-14 w-14 rounded-xl bg-gradient-to-br from-utem-blue to-utem-blueDark flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-utem-dark mb-2">Correo Oficial</h3>
          <p class="text-utem-dark/70 text-sm">Comunicación formal y consultas académicas</p>
        </div>
        
        <a 
          href="mailto:ce.iccd@utem.cl" 
          class="group/btn inline-flex items-center gap-2 text-lg font-bold text-utem-blue hover:text-utem-purple transition-colors"
        >
          ce.iccd@utem.cl
          <span class="opacity-0 group-hover/btn:opacity-100 group-hover/btn:translate-x-1 transition-all duration-300">→</span>
        </a>
        <p class="text-xs text-utem-dark/50 mt-2">Respuesta en 24-48 horas hábiles</p>
      </div>

      <!-- Instagram -->
      <div class="group relative rounded-xl border border-utem-gray/50 bg-gradient-card p-6 shadow-subtle hover:shadow-glow hover:border-utem-purple/30 transition-all duration-300 overflow-hidden">
        <div class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-utem-purple/10 blur-xl group-hover:scale-150 transition-transform duration-500"></div>
        
        <div class="mb-6">
          <div class="h-14 w-14 rounded-xl bg-gradient-to-br from-utem-purple to-utem-magenta flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-utem-dark mb-2">Instagram</h3>
          <p class="text-utem-dark/70 text-sm">Noticias, eventos y comunidad activa</p>
        </div>
        
        <a 
          href="https://www.instagram.com/ceedatos/" 
          target="_blank"
          class="group/btn inline-flex items-center gap-2 text-lg font-bold text-utem-purple hover:text-utem-magenta transition-colors"
        >
          @ceedatos
          <span class="opacity-0 group-hover/btn:opacity-100 group-hover/btn:translate-x-1 transition-all duration-300">→</span>
        </a>
        <p class="text-xs text-utem-dark/50 mt-2">Síguenos para actualizaciones diarias</p>
      </div>

      <!-- Drive -->
      <div class="group relative rounded-xl border border-utem-gray/50 bg-gradient-card p-6 shadow-subtle hover:shadow-glow hover:border-utem-teal/30 transition-all duration-300 overflow-hidden">
        <div class="absolute -top-10 -right-10 h-20 w-20 rounded-full bg-utem-teal/10 blur-xl group-hover:scale-150 transition-transform duration-500"></div>
        
        <div class="mb-6">
          <div class="h-14 w-14 rounded-xl bg-gradient-to-br from-utem-teal to-utem-green flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-utem-dark mb-2">Drive Académico</h3>
          <p class="text-utem-dark/70 text-sm">Materiales, apuntes y recursos UTEM</p>
        </div>
        
        <a 
          href="https://drive.google.com/drive/folders/1Q505dFbrA1FYVnRMqswJMDX4iOAqV-BV?usp=sharing" 
          target="_blank"
          class="group/btn inline-flex items-center gap-2 text-lg font-bold text-utem-teal hover:text-utem-green transition-colors"
        >
          Material UTEM
          <span class="opacity-0 group-hover/btn:opacity-100 group-hover/btn:translate-x-1 transition-all duration-300">→</span>
        </a>
        <p class="text-xs text-utem-dark/50 mt-2">Acceso 24/7 para estudiantes ICCD</p>
      </div>
    </div>

    <!-- Sección adicional -->
    <section class="rounded-2xl border border-utem-gray/50 bg-gradient-to-r from-utem-skySoft/20 to-white p-8 shadow-subtle">
      <div class="flex flex-col md:flex-row items-center gap-6">
        <div class="h-16 w-16 rounded-xl bg-gradient-to-br from-utem-blue to-utem-purple flex items-center justify-center flex-shrink-0">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="text-xl font-bold text-utem-dark mb-2">¿Quieres ser parte del CE ICCD?</h3>
          <p class="text-utem-dark/80 mb-4">
            El Centro de Estudiantes está abierto a nuevos integrantes. Si tienes interés en participar, 
            organizar eventos o contribuir con proyectos, escríbenos o asiste a nuestras reuniones.
          </p>
        </div>
        <a 
          href="mailto:ce.iccd@utem.cl?subject=Interés%20en%20participar%20CE%20ICCD&body=Hola,%20me%20interesa%20ser%20parte%20del%20Centro%20de%20Estudiantes.%0A%0ANombre:%0ACarrera:%0ASemestre:%0A%0AMotivación:%0A%0A"
          class="group rounded-full bg-gradient-utem px-6 py-3 text-white font-bold hover:shadow-glow hover:scale-105 transition-all duration-300"
        >
          Postular al CE
          <span class="ml-2 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300">→</span>
        </a>
      </div>
    </section>

    <!-- Info rápida -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-lg border border-utem-gray/50 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-utem-blue mb-1">24/7</div>
        <p class="text-sm text-utem-dark/70">Drive disponible</p>
      </div>
      <div class="rounded-lg border border-utem-gray/50 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-utem-purple mb-1">48h</div>
        <p class="text-sm text-utem-dark/70">Respuesta email</p>
      </div>
      <div class="rounded-lg border border-utem-gray/50 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-utem-teal mb-1">100%</div>
        <p class="text-sm text-utem-dark/70">Estudiantes ICCD</p>
      </div>
      <div class="rounded-lg border border-utem-gray/50 bg-white p-4 text-center">
        <div class="text-2xl font-bold text-utem-green mb-1">UTEM</div>
        <p class="text-sm text-utem-dark/70">Comunidad oficial</p>
      </div>
    </div>
  </div>
</MainLayout>