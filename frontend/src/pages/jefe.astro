---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/global.css';
---

<MainLayout>
  <div class="space-y-8 animate-fade-in">
    
    <!-- Header con gradiente solemne -->
    <header class="relative overflow-hidden rounded-2xl border border-utem-gray/50 bg-gradient-to-r from-utem-blueDark via-utem-blue to-utem-purple p-8 md:p-10 shadow-glow">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/4 h-40 w-40 rounded-full bg-white/5 blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 h-40 w-40 rounded-full bg-utem-purple/10 blur-3xl"></div>
      </div>
      
      <div class="relative z-10 space-y-4 text-center md:text-left">
        <div class="inline-flex items-center gap-3 mx-auto md:mx-0">
          <div class="h-1 w-8 rounded-full bg-white/60"></div>
          <p class="text-sm font-bold uppercase tracking-wider text-white/90">Jefe de Carrera</p>
          <div class="h-1 w-8 rounded-full bg-white/60"></div>
        </div>
        
        <h1 class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Dr. Jorge Ramón<br/>
          <span class="text-utem-skySoft">Vergara Quezada</span>
        </h1>
        
        <p class="text-xl text-white/90 max-w-2xl mx-auto md:mx-0">
          Doctor en Ingeniería Eléctrica - Académico del Departamento de Informática y Computación UTEM
        </p>
      </div>
    </header>

    <!-- Contenido principal -->
    <div class="grid gap-8 lg:grid-cols-3">
      
      <!-- Columna izquierda: Información principal -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Tarjeta de perfil -->
        <div class="group relative rounded-2xl border border-utem-gray/50 bg-gradient-card p-8 shadow-subtle hover:shadow-lg transition-all duration-300 overflow-hidden">
          <div class="absolute -top-10 -right-10 h-32 w-32 rounded-full bg-utem-blue/5 blur-xl group-hover:scale-150 transition-transform duration-700"></div>
          
          <div class="flex flex-col md:flex-row items-start md:items-center gap-6 mb-8">
            <!-- Foto jefe de carrera -->
            <div class="relative h-48 w-48 rounded-2xl overflow-hidden border-4 border-white shadow-lg mx-auto md:mx-0">
              <img
                src="/imagenes/Jorge.png"
                alt="Dr. Jorge Ramon Vergara Quezada"
                class="h-full w-full object-cover object-center"
                loading="lazy"
              />
            </div>
            
            <!-- Info rápida -->
            <div class="flex-1 space-y-4">
              <div>
                <h3 class="text-lg font-bold text-utem-dark/70 mb-1">Cargo Actual</h3>
                <p class="text-2xl font-bold text-utem-blue">Jefe de Carrera ICCD</p>
                <p class="text-utem-dark/70">Ingeniería Civil en Ciencia de Datos</p>
              </div>
              
              <div>
                <h3 class="text-lg font-bold text-utem-dark/70 mb-1">Departamento</h3>
                <p class="text-xl text-utem-dark">Informática y Computación</p>
                <p class="text-sm text-utem-dark/70">Facultad de Ingeniería UTEM</p>
              </div>
              
              <div>
                <h3 class="text-lg font-bold text-utem-dark/70 mb-1">Títulos Académicos</h3>
                <div class="space-y-2">
                  <p class="text-utem-dark flex items-center gap-2">
                    <div class="h-2 w-2 rounded-full bg-utem-blue"></div>
                    Doctor en Ingeniería Eléctrica
                  </p>
                  <p class="text-utem-dark flex items-center gap-2">
                    <div class="h-2 w-2 rounded-full bg-utem-purple"></div>
                    Ingeniero Civil Electrónico
                  </p>
                  <p class="text-utem-dark flex items-center gap-2">
                    <div class="h-2 w-2 rounded-full bg-utem-teal"></div>
                    Licenciado en Ciencias de la Ingeniería
                  </p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Descripción -->
          <div class="space-y-4">
            <h3 class="text-2xl font-bold text-utem-dark border-l-4 border-utem-blue pl-4">Académico UTEM</h3>
            <div class="space-y-3 text-utem-dark/80 leading-relaxed">
              <p>Doctor en Ingeniería Eléctrica con especialización en <strong class="text-utem-blue">Machine Learning y Deep Learning</strong>. Académico del Departamento de Informática y Computación de la UTEM.</p>
              <p>Lidera la carrera de <strong class="text-utem-purple">Ingeniería Civil en Ciencia de Datos</strong>, coordinando el desarrollo curricular, bienestar estudiantil y vinculación con la industria tecnológica.</p>
              <p>Su investigación se centra en <strong class="text-utem-teal">series de tiempo, computación evolutiva y aprendizaje profundo</strong>, aplicados a problemas de ingeniería y ciencia de datos.</p>
            </div>
          </div>
        </div>
        
        <!-- Asignaturas que dicta -->
        <div class="rounded-2xl border border-utem-gray/50 bg-white p-8 shadow-subtle">
          <h3 class="text-2xl font-bold text-utem-dark mb-6 flex items-center gap-3">
            <div class="h-2 w-8 rounded-full bg-gradient-to-r from-utem-blue to-utem-purple"></div>
            Asignaturas que Dicta
          </h3>
          
          <div class="grid gap-4 md:grid-cols-2">
            <div class="group rounded-xl border border-utem-gray/50 p-5 hover:border-utem-blue/50 hover:bg-blue-50/30 transition-all duration-300">
              <h4 class="font-bold text-utem-blue mb-2">Machine Learning</h4>
              <p class="text-sm text-utem-dark/70">
                Ingeniería Civil en Computación mención Informática<br/>
                Ingeniería en Informática
              </p>
            </div>
            
            <div class="group rounded-xl border border-utem-gray/50 p-5 hover:border-utem-purple/50 hover:bg-purple-50/30 transition-all duration-300">
              <h4 class="font-bold text-utem-purple mb-2">Arquitectura de Computadores</h4>
              <p class="text-sm text-utem-dark/70">
                Ingeniería Civil en Computación mención Informática
              </p>
            </div>
            
            <div class="group rounded-xl border border-utem-gray/50 p-5 hover:border-utem-teal/50 hover:bg-teal-50/30 transition-all duration-300">
              <h4 class="font-bold text-utem-teal mb-2">Tecnología de Computadores</h4>
              <p class="text-sm text-utem-dark/70">
                Ingeniería Civil en Computación mención Informática<br/>
                Ingeniería en Informática
              </p>
            </div>
            
            <div class="group rounded-xl border border-utem-gray/50 p-5 hover:border-utem-green/50 hover:bg-green-50/30 transition-all duration-300">
              <h4 class="font-bold text-utem-green mb-2">Trabajo de Titulación I/II</h4>
              <p class="text-sm text-utem-dark/70">
                Ingeniería Civil en Computación mención Informática<br/>
                Ingeniería en Informática
              </p>
            </div>
          </div>
        </div>
        
        <!-- Líneas de investigación -->
        <div class="rounded-2xl border border-utem-gray/50 bg-gradient-to-r from-utem-skySoft/20 to-white p-8 shadow-subtle">
          <h3 class="text-2xl font-bold text-utem-dark mb-6 flex items-center gap-3">
            <div class="h-2 w-8 rounded-full bg-utem-teal"></div>
            Líneas de Investigación
          </h3>
          
          <div class="flex flex-wrap gap-3">
            <span class="px-4 py-2 rounded-full bg-gradient-to-r from-utem-blue/10 to-utem-blue/20 text-utem-blue font-bold border border-utem-blue/30">
              Machine Learning
            </span>
            <span class="px-4 py-2 rounded-full bg-gradient-to-r from-utem-purple/10 to-utem-purple/20 text-utem-purple font-bold border border-utem-purple/30">
              Deep Learning
            </span>
            <span class="px-4 py-2 rounded-full bg-gradient-to-r from-utem-teal/10 to-utem-teal/20 text-utem-teal font-bold border border-utem-teal/30">
              Time Series Forecasting
            </span>
            <span class="px-4 py-2 rounded-full bg-gradient-to-r from-utem-green/10 to-utem-green/20 text-utem-green font-bold border border-utem-green/30">
              Computación Evolutiva
            </span>
            <span class="px-4 py-2 rounded-full bg-gradient-to-r from-utem-blue/10 to-utem-purple/20 text-utem-purpleDark font-bold border border-utem-purple/30">
              Análisis de Series de Tiempo
            </span>
          </div>
          
          <div class="mt-6 pt-6 border-t border-utem-gray/50">
            <h4 class="font-bold text-utem-dark mb-3">Enlaces de Investigación:</h4>
            <div class="space-y-2">
              <a href="https://scholar.google.com/citations?user=qpJ_rjoAAAAJ&hl=es" 
                 target="_blank"
                 class="flex items-center gap-3 text-utem-blue hover:text-utem-blueDark hover:underline">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm-2 17.37c-2.45 0-4.45-2-4.45-4.45s2-4.45 4.45-4.45 4.45 2 4.45 4.45-2 4.45-4.45 4.45zm9-11.19c-1.34 0-2.45-1.11-2.45-2.45s1.11-2.45 2.45-2.45 2.45 1.11 2.45 2.45-1.11 2.45-2.45 2.45z"/>
                </svg>
                Google Scholar
              </a>
              <a href="http://orcid.org/0000-0001-6699-4181" 
                 target="_blank"
                 class="flex items-center gap-3 text-utem-green hover:text-utem-greenDark hover:underline">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM9 16.57V7.43A.43.43 0 0 1 9.43 7h5.14a.43.43 0 0 1 .43.43v9.14a.43.43 0 0 1-.43.43H9.43a.43.43 0 0 1-.43-.43z"/>
                </svg>
                ORCID: 0000-0001-6699-4181
              </a>
              <a href="https://dblp.org/pers/hd/v/Vergara:Jorge_R=" 
                 target="_blank"
                 class="flex items-center gap-3 text-utem-purple hover:text-utem-purpleDark hover:underline">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zM6 6h4v4H6V6zm0 8h4v4H6v-4zm8 0h4v4h-4v-4zm0-8h4v4h-4V6z"/>
                </svg>
                DBLP Computer Science Bibliography
              </a>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Columna derecha: Contacto y info lateral -->
      <div class="space-y-6">
        
        <!-- Información de contacto -->
        <div class="rounded-2xl border border-utem-gray/50 bg-gradient-to-b from-white to-blue-50/30 p-8 shadow-subtle">
          <h3 class="text-2xl font-bold text-utem-dark mb-6 flex items-center gap-3">
            <div class="h-2 w-8 rounded-full bg-utem-blue"></div>
            Información de Contacto
          </h3>
          
          <div class="space-y-6">
            <div class="group flex items-center gap-4 p-4 rounded-xl border border-utem-gray/50 hover:border-utem-blue/50 hover:bg-white transition-all duration-300">
              <div class="h-12 w-12 rounded-lg bg-gradient-to-br from-utem-blue to-utem-blueDark flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-utem-dark/70 mb-1">Correo Institucional</p>
                <a href="mailto:carrera21049@utem.cl" class="text-lg font-bold text-utem-blue hover:text-utem-blueDark hover:underline break-all">
                  carrera21049@utem.cl
                </a>
              </div>
            </div>
            
            <div class="group flex items-center gap-4 p-4 rounded-xl border border-utem-gray/50 hover:border-utem-purple/50 hover:bg-white transition-all duration-300">
              <div class="h-12 w-12 rounded-lg bg-gradient-to-br from-utem-purple to-utem-purpleDark flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-utem-dark/70 mb-1">Ubicación</p>
                <p class="text-lg font-bold text-utem-dark">Campus UTEM Ñuñoa</p>
                <p class="text-sm text-utem-dark/70 mt-1">
                  José Pedro Alessandri 1242<br/>
                  Ñuñoa, Santiago
                </p>
              </div>
            </div>
            
            <div class="group flex items-center gap-4 p-4 rounded-xl border border-utem-gray/50 hover:border-utem-teal/50 hover:bg-white transition-all duration-300">
              <div class="h-12 w-12 rounded-lg bg-gradient-to-br from-utem-teal to-utem-green flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-utem-dark/70 mb-1">Teléfono</p>
                <p class="text-lg font-bold text-utem-dark">No disponible</p>
                <p class="text-sm text-utem-dark/70 mt-1">Departamento de Informática y Computación</p>
              </div>
            </div>
            
            <div class="group flex items-center gap-4 p-4 rounded-xl border border-utem-gray/50 hover:border-utem-green/50 hover:bg-white transition-all duration-300">
              <div class="h-12 w-12 rounded-lg bg-gradient-to-br from-utem-green to-utem-blue flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-utem-dark/70 mb-1">Sitio Web</p>
                <a href="http://fing.utem.cl/" 
                   target="_blank"
                   class="text-lg font-bold text-utem-green hover:text-utem-greenDark hover:underline">
                  Facultad de Ingeniería UTEM
                </a>
              </div>
            </div>
          </div>
          
          <div class="mt-8 pt-6 border-t border-utem-gray/50">
            <p class="text-sm text-utem-dark/70 mb-4">
              Para consultas académicas o coordinación de reuniones, contactar vía correo institucional.
            </p>
            <a 
              href="mailto:carrera21049@utem.cl?subject=Consulta%20Académica%20-%20ICCD%20UTEM"
              class="group w-full rounded-xl bg-gradient-to-r from-utem-blue to-utem-purple py-4 text-white font-bold text-center hover:shadow-glow hover:scale-[1.02] transition-all duration-300 block"
            >
              <span class="flex items-center justify-center gap-2">
                Contactar por Correo
                <svg class="w-5 h-5 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </span>
            </a>
          </div>
        </div>
        
        <!-- Datos académicos -->
        <div class="rounded-2xl border border-utem-gray/50 bg-gradient-to-b from-white to-purple-50/30 p-8 shadow-subtle">
          <h3 class="text-2xl font-bold text-utem-dark mb-6 flex items-center gap-3">
            <div class="h-2 w-8 rounded-full bg-utem-purple"></div>
            Formación Académica
          </h3>
          
          <div class="space-y-4">
            <div class="p-4 rounded-xl bg-gradient-to-r from-utem-blue/5 to-transparent">
              <p class="text-sm font-medium text-utem-dark/70 mb-1">Doctorado</p>
              <p class="text-lg font-bold text-utem-blue">Doctor en Ingeniería Eléctrica</p>
            </div>
            
            <div class="p-4 rounded-xl bg-gradient-to-r from-utem-purple/5 to-transparent">
              <p class="text-sm font-medium text-utem-dark/70 mb-1">Título Profesional</p>
              <p class="text-lg font-bold text-utem-purple">Ingeniero Civil Electrónico</p>
            </div>
            
            <div class="p-4 rounded-xl bg-gradient-to-r from-utem-teal/5 to-transparent">
              <p class="text-sm font-medium text-utem-dark/70 mb-1">Grado Académico</p>
              <p class="text-lg font-bold text-utem-teal">Licenciado en Ciencias de la Ingeniería</p>
            </div>
            
            <div class="p-4 rounded-xl bg-gradient-to-r from-utem-green/5 to-transparent">
              <p class="text-sm font-medium text-utem-dark/70 mb-1">Años en UTEM</p>
              <p class="text-3xl font-bold text-utem-green">15+</p>
              <p class="text-sm text-utem-dark/70">Experiencia académica e investigación</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>


