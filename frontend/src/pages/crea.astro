---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/global.css';

const apiBase = (import.meta.env.PUBLIC_PROJECTS_API_URL || '/api').replace(/\/$/, '');
---

<MainLayout fullBleed={true} hideFooter={true}>
  <div id="crea-page" class="w-full overflow-hidden bg-slate-100">
    <section class="grid h-full grid-cols-[172px_minmax(0,1fr)] gap-0">
      <aside class="h-full overflow-y-auto border-r border-utem-gray/70 bg-white/95 p-3 shadow-subtle">
        <div id="crea-access-panel" class="rounded-xl border border-utem-blue/30 bg-utem-blue/5 p-3">
          <p class="text-[11px] font-bold uppercase tracking-wide text-utem-blue">Cuenta UTEM</p>
          <p id="crea-access-status" class="mt-2 text-xs leading-relaxed text-utem-dark/80">
            Validando acceso...
          </p>
          <a
            id="crea-access-link"
            href="/login/?returnTo=%2Fcrea%2F"
            class="mt-3 inline-flex rounded-full bg-gradient-utem px-4 py-2 text-[11px] font-bold text-white"
          >
            Ingresar
          </a>
        </div>

        <div class="space-y-2">
          <button
            id="tool-draw"
            type="button"
            class="w-full rounded-xl border border-utem-blue/70 bg-utem-blue px-2 py-3 text-[11px] font-bold uppercase tracking-wide text-white transition hover:bg-utem-blueDark"
          >
            Lapiz
          </button>
          <button
            id="tool-erase"
            type="button"
            class="w-full rounded-xl border border-utem-gray/70 bg-white px-2 py-3 text-[11px] font-bold uppercase tracking-wide text-utem-dark transition hover:border-utem-blue"
          >
            Goma
          </button>
          <button
            id="tool-move"
            type="button"
            class="w-full rounded-xl border border-utem-gray/70 bg-white px-2 py-3 text-[11px] font-bold uppercase tracking-wide text-utem-dark transition hover:border-utem-blue"
          >
            Mover
          </button>
          <button
            id="tool-select"
            type="button"
            class="w-full rounded-xl border border-utem-gray/70 bg-white px-2 py-3 text-[11px] font-bold uppercase tracking-wide text-utem-dark transition hover:border-utem-blue"
          >
            Selector
          </button>
        </div>

        <div class="mt-3 rounded-xl border border-utem-gray/60 bg-white p-2">
          <button
            id="toggle-size-panel"
            type="button"
            class="flex w-full items-center justify-between rounded-lg border border-utem-gray/60 bg-white px-2 py-2 text-xs font-semibold text-utem-dark transition hover:border-utem-blue"
          >
            <span id="size-mode-label">Grosor Lapiz</span>
            <span id="size-toggle-symbol" class="text-base leading-none">+</span>
          </button>

          <div id="size-panel" class="mt-2 hidden rounded-lg border border-utem-gray/60 bg-utem-skySoft/10 p-2">
            <div id="brush-size-value" class="text-center text-xs font-bold text-utem-blue">8px</div>
            <input
              id="brush-size"
              type="range"
              min="1"
              max="420"
              value="8"
              class="mt-2 h-4 w-full cursor-pointer appearance-none rounded-lg bg-utem-gray accent-utem-blue"
            />
          </div>
        </div>

        <div class="mt-3 rounded-xl border border-utem-gray/60 bg-white p-2">
          <label for="brush-color" class="block text-[11px] font-semibold text-utem-dark/80">Color</label>
          <input
            id="brush-color"
            type="color"
            value="#005DA4"
            class="mt-1 h-9 w-full cursor-pointer rounded-md border border-utem-gray/70 bg-white"
          />
          <div class="mt-2 grid grid-cols-3 gap-1.5">
            <button type="button" data-color="#005DA4" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#005DA4;" aria-label="Color 1"></button>
            <button type="button" data-color="#009639" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#009639;" aria-label="Color 2"></button>
            <button type="button" data-color="#E11D48" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#E11D48;" aria-label="Color 3"></button>
            <button type="button" data-color="#111827" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#111827;" aria-label="Color 4"></button>
            <button type="button" data-color="#F97316" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#F97316;" aria-label="Color 5"></button>
            <button type="button" data-color="#FACC15" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#FACC15;" aria-label="Color 6"></button>
            <button type="button" data-color="#14B8A6" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#14B8A6;" aria-label="Color 7"></button>
            <button type="button" data-color="#2563EB" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#2563EB;" aria-label="Color 8"></button>
            <button type="button" data-color="#7C3AED" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#7C3AED;" aria-label="Color 9"></button>
            <button type="button" data-color="#EC4899" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#EC4899;" aria-label="Color 10"></button>
            <button type="button" data-color="#A16207" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#A16207;" aria-label="Color 11"></button>
            <button type="button" data-color="#4B5563" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#4B5563;" aria-label="Color 12"></button>
            <button type="button" data-color="#FCA5A5" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#FCA5A5;" aria-label="Color 13"></button>
            <button type="button" data-color="#86EFAC" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#86EFAC;" aria-label="Color 14"></button>
            <button type="button" data-color="#93C5FD" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#93C5FD;" aria-label="Color 15"></button>
            <button type="button" data-color="#DDD6FE" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#DDD6FE;" aria-label="Color 16"></button>
            <button type="button" data-color="#FB7185" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#FB7185;" aria-label="Color 17"></button>
            <button type="button" data-color="#0F766E" class="color-swatch h-7 rounded-md border border-slate-300" style="background:#0F766E;" aria-label="Color 18"></button>
          </div>
        </div>

        <div class="mt-3 rounded-xl border border-utem-blue/40 bg-utem-skySoft/10 p-2">
          <p class="text-center text-[11px] font-semibold uppercase tracking-wider text-utem-blue">Zoom</p>
          <div class="mt-2 grid grid-cols-2 gap-2">
            <button
              id="zoom-out"
              type="button"
              class="h-16 rounded-xl border border-utem-blue/60 bg-white text-5xl font-bold leading-none text-utem-blue transition hover:bg-utem-blue/10"
              aria-label="Achicar"
            >
              -
            </button>
            <button
              id="zoom-in"
              type="button"
              class="h-16 rounded-xl border border-utem-blue/60 bg-white text-5xl font-bold leading-none text-utem-blue transition hover:bg-utem-blue/10"
              aria-label="Agrandar"
            >
              +
            </button>
          </div>
          <div id="zoom-level" class="mt-2 text-center text-sm font-extrabold text-utem-blue">100%</div>
          <input
            id="zoom-slider"
            type="range"
            min="5"
            max="2000"
            value="55"
            class="mt-2 h-4 w-full cursor-pointer appearance-none rounded-lg bg-utem-gray accent-utem-blue"
          />
          <div class="mt-2 grid grid-cols-2 gap-1.5">
            <button type="button" data-zoom="25" class="zoom-preset rounded-md border border-utem-gray/70 bg-white px-1 py-1 text-[10px] font-semibold text-utem-dark">25%</button>
            <button type="button" data-zoom="100" class="zoom-preset rounded-md border border-utem-gray/70 bg-white px-1 py-1 text-[10px] font-semibold text-utem-dark">100%</button>
            <button type="button" data-zoom="300" class="zoom-preset rounded-md border border-utem-gray/70 bg-white px-1 py-1 text-[10px] font-semibold text-utem-dark">300%</button>
            <button type="button" data-zoom="800" class="zoom-preset rounded-md border border-utem-gray/70 bg-white px-1 py-1 text-[10px] font-semibold text-utem-dark">800%</button>
          </div>
        </div>

        <div class="mt-3 grid grid-cols-1 gap-2">
          <button
            id="reset-view"
            type="button"
            class="rounded-xl border border-utem-gray/70 bg-white px-2 py-2 text-[11px] font-semibold text-utem-dark transition hover:border-utem-blue"
          >
            Centrar
          </button>
        </div>

        <div class="mt-3 rounded-xl border border-utem-gray/60 bg-white p-2 text-[10px] leading-tight text-utem-dark/80">
          <p><strong>Modo:</strong> <span id="active-tool">Lapiz</span></p>
          <p>Rueda: zoom rapido</p>
          <p>Espacio: mover temporal</p>
          <p>Ctrl+V: pegar imagen</p>
          <p>Selector: click imagen para mover</p>
          <p>Manilla azul: agrandar/achicar</p>
          <p>Guardado automatico compartido</p>
        </div>
      </aside>

      <div class="h-full p-2 md:p-3">
        <div
          id="canvas-wrapper"
          class="relative h-full overflow-hidden rounded-2xl border border-utem-gray/70 bg-slate-200 shadow-subtle"
        >
          <div
            id="crea-readonly-notice"
            class="hidden absolute left-3 top-3 z-20 max-w-sm rounded-2xl border border-utem-blue/30 bg-white/95 px-4 py-3 text-xs leading-relaxed text-utem-dark/80 shadow-sm"
          >
            Inicia sesion con tu correo <strong>@utem.cl</strong> para dibujar o pegar imagenes en este espacio.
          </div>
          <canvas id="paint-canvas" class="absolute inset-0 h-full w-full touch-none"></canvas>
          <div
            class="pointer-events-none absolute right-3 top-3 rounded-lg border border-utem-gray/50 bg-white/90 px-3 py-2 text-xs text-utem-dark/80 shadow-sm"
          >
            Arrastra para dibujar | rueda para zoom | click derecho para mover
          </div>
        </div>
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ apiBase }}>
    window.CE_API_BASE = apiBase;
  </script>

  <script>
    const pageRoot = document.getElementById('crea-page');
    const siteHeader = document.querySelector('header');
    const canvas = document.getElementById('paint-canvas');
    const canvasWrapper = document.getElementById('canvas-wrapper');
    const accessPanel = document.getElementById('crea-access-panel');
    const accessStatus = document.getElementById('crea-access-status');
    const accessLink = document.getElementById('crea-access-link');
    const readonlyNotice = document.getElementById('crea-readonly-notice');
    const drawButton = document.getElementById('tool-draw');
    const moveButton = document.getElementById('tool-move');
    const eraseButton = document.getElementById('tool-erase');
    const selectButton = document.getElementById('tool-select');
    const colorInput = document.getElementById('brush-color');
    const toggleSizePanelButton = document.getElementById('toggle-size-panel');
    const sizePanel = document.getElementById('size-panel');
    const sizeModeLabel = document.getElementById('size-mode-label');
    const sizeToggleSymbol = document.getElementById('size-toggle-symbol');
    const sizeInput = document.getElementById('brush-size');
    const sizeValue = document.getElementById('brush-size-value');
    const zoomLevel = document.getElementById('zoom-level');
    const zoomInButton = document.getElementById('zoom-in');
    const zoomOutButton = document.getElementById('zoom-out');
    const zoomSlider = document.getElementById('zoom-slider');
    const activeTool = document.getElementById('active-tool');
    const resetViewButton = document.getElementById('reset-view');
    const swatches = Array.from(document.querySelectorAll('.color-swatch'));
    const zoomPresets = Array.from(document.querySelectorAll('.zoom-preset'));

    if (
      !pageRoot ||
      !canvas ||
      !canvasWrapper ||
      !accessPanel ||
      !accessStatus ||
      !accessLink ||
      !readonlyNotice ||
      !drawButton ||
      !moveButton ||
      !eraseButton ||
      !selectButton ||
      !colorInput ||
      !toggleSizePanelButton ||
      !sizePanel ||
      !sizeModeLabel ||
      !sizeToggleSymbol ||
      !sizeInput ||
      !sizeValue ||
      !zoomLevel ||
      !zoomInButton ||
      !zoomOutButton ||
      !zoomSlider ||
      !activeTool ||
      !resetViewButton
    ) {
      throw new Error('No se pudieron inicializar los controles del lienzo.');
    }

    const context = canvas.getContext('2d');
    if (!context) {
      throw new Error('No se pudo crear el contexto 2D del canvas.');
    }

    const world = { width: 60000, height: 60000 };
    const apiBase = window.CE_API_BASE || '/api';
    const studentTokenKey = 'ce-student-token';
    const adminTokenKey = 'ce-admin-token';
    const CACHE_KEY = 'ce-iccd-crea-board-cache-v5';
    const STORAGE_VERSION = 5;
    const MAX_STROKES_TO_LOAD = 7000;
    const MAX_POINTS_TO_LOAD = 220000;
    const SAVE_DEBOUNCE_MS = 420;
    const BOARD_POLL_INTERVAL_MS = 12000;
    const MAX_IMAGE_SIDE = 8000;
    const MIN_IMAGE_SIDE = 80;
    const IMAGE_HANDLE_SCREEN_SIZE = 18;
    const IMAGE_HIT_PADDING_SCREEN = 10;
    const BRUSH_MIN = 1;
    const BRUSH_MAX = 420;
    const ERASER_MIN = 20;
    const ERASER_MAX = 1200;
    const initialZoom = 0.55;

    const state = {
      dpr: window.devicePixelRatio || 1,
      viewportWidth: 0,
      viewportHeight: 0,
      tool: 'draw',
      brushColor: colorInput.value || '#005DA4',
      brushSize: Number(sizeInput.value) || 8,
      eraserSize: 240,
      zoom: initialZoom,
      minZoom: 0.05,
      maxZoom: 20,
      cameraX: world.width / 2,
      cameraY: world.height / 2,
      spacePan: false,
      isPanning: false,
      panPointerId: null,
      drawPointerId: null,
      lastPointerX: 0,
      lastPointerY: 0,
      pointerX: 0,
      pointerY: 0,
      pointerInside: false,
      activeStroke: null,
      strokes: [],
      sizePanelOpen: false,
      selectedImageIndex: -1,
      dragImagePointerId: null,
      resizeImagePointerId: null,
      imageDragOffsetX: 0,
      imageDragOffsetY: 0,
      resizeStartWorldX: 0,
      resizeStartWorldY: 0,
      resizeStartWidth: 0,
      resizeStartHeight: 0,
      canEdit: false,
      boardUpdatedAt: '',
      boardUpdatedBy: '',
    };
    let saveTimer = null;
    let boardPollTimer = null;
    let isSavingBoard = false;
    let hasPendingBoardChanges = false;
    const imageCache = new Map();
    const editControls = [
      drawButton,
      eraseButton,
      selectButton,
      colorInput,
      toggleSizePanelButton,
      sizeInput,
      ...swatches,
    ];

    function clamp(value, min, max) {
      return Math.min(Math.max(value, min), max);
    }

    function isHexColor(value) {
      return typeof value === 'string' && /^#[\da-fA-F]{6}$/.test(value);
    }

    function toolLabel(tool) {
      if (tool === 'move') return 'Mover';
      if (tool === 'select') return 'Selector';
      if (tool === 'erase') return 'Goma';
      return 'Lapiz';
    }

    function normalizeImagePlacement(x, y, width, height) {
      const safeWidth = clamp(width, MIN_IMAGE_SIDE, Math.min(MAX_IMAGE_SIDE, world.width));
      const safeHeight = clamp(height, MIN_IMAGE_SIDE, Math.min(MAX_IMAGE_SIDE, world.height));
      const maxX = Math.max(0, world.width - safeWidth);
      const maxY = Math.max(0, world.height - safeHeight);

      return {
        x: clamp(x, 0, maxX),
        y: clamp(y, 0, maxY),
        width: safeWidth,
        height: safeHeight,
      };
    }

    function sanitizeBoardElement(rawElement) {
      if (!rawElement || typeof rawElement !== 'object') return null;

      if (rawElement.mode === 'image') {
        if (typeof rawElement.src !== 'string' || !rawElement.src.startsWith('data:image/')) return null;
        const width = Number(rawElement.width);
        const height = Number(rawElement.height);
        const x = Number(rawElement.x);
        const y = Number(rawElement.y);
        if (!Number.isFinite(width) || !Number.isFinite(height) || !Number.isFinite(x) || !Number.isFinite(y)) {
          return null;
        }

        const placement = normalizeImagePlacement(x, y, width, height);
        return {
          mode: 'image',
          src: rawElement.src,
          x: placement.x,
          y: placement.y,
          width: placement.width,
          height: placement.height,
        };
      }

      if (!Array.isArray(rawElement.points)) return null;
      const mode = rawElement.mode === 'erase' ? 'erase' : 'draw';
      const maxSize = mode === 'erase' ? ERASER_MAX : BRUSH_MAX;
      const minSize = mode === 'erase' ? ERASER_MIN : BRUSH_MIN;
      const size = clamp(Number(rawElement.size) || minSize, minSize, maxSize);
      const color = isHexColor(rawElement.color) ? rawElement.color : '#005DA4';
      const points = [];

      for (const point of rawElement.points) {
        if (!point || !Number.isFinite(point.x) || !Number.isFinite(point.y)) continue;
        points.push({
          x: clamp(Number(point.x), 0, world.width),
          y: clamp(Number(point.y), 0, world.height),
        });
      }

      if (!points.length) return null;
      return { mode, color, size, points };
    }

    function getSelectedImageElement() {
      if (state.selectedImageIndex < 0 || state.selectedImageIndex >= state.strokes.length) return null;
      const element = state.strokes[state.selectedImageIndex];
      return element?.mode === 'image' ? element : null;
    }

    function getImageIndexAtWorldPoint(worldX, worldY) {
      const padding = IMAGE_HIT_PADDING_SCREEN / state.zoom;

      for (let i = state.strokes.length - 1; i >= 0; i -= 1) {
        const element = state.strokes[i];
        if (element?.mode !== 'image') continue;
        if (
          worldX >= element.x - padding &&
          worldX <= element.x + element.width + padding &&
          worldY >= element.y - padding &&
          worldY <= element.y + element.height + padding
        ) {
          return i;
        }
      }

      return -1;
    }

    function getImageHandleWorldRect(imageElement) {
      const side = IMAGE_HANDLE_SCREEN_SIZE / state.zoom;
      return {
        x: imageElement.x + imageElement.width - side,
        y: imageElement.y + imageElement.height - side,
        width: side,
        height: side,
      };
    }

    function isPointInImageHandle(worldX, worldY, imageElement) {
      const handle = getImageHandleWorldRect(imageElement);
      return (
        worldX >= handle.x &&
        worldX <= handle.x + handle.width &&
        worldY >= handle.y &&
        worldY <= handle.y + handle.height
      );
    }

    function bringImageElementToFront(index) {
      if (index < 0 || index >= state.strokes.length) return -1;
      const [element] = state.strokes.splice(index, 1);
      if (!element) return -1;
      state.strokes.push(element);
      return state.strokes.length - 1;
    }

    function getEditorToken() {
      return (
        window.localStorage.getItem(studentTokenKey) ||
        window.localStorage.getItem(adminTokenKey) ||
        ''
      );
    }

    function hasActiveInteraction() {
      return Boolean(
        state.activeStroke ||
        state.drawPointerId !== null ||
        state.dragImagePointerId !== null ||
        state.resizeImagePointerId !== null ||
        state.panPointerId !== null ||
        state.isPanning
      );
    }

    function buildBoardPayload() {
      return {
        version: STORAGE_VERSION,
        brushColor: state.brushColor,
        brushSize: state.brushSize,
        eraserSize: state.eraserSize,
        strokes: state.strokes,
      };
    }

    function readBoardCachePayload() {
      try {
        const raw = localStorage.getItem(CACHE_KEY);
        if (!raw) return null;
        const parsed = JSON.parse(raw);
        if (!parsed || !Array.isArray(parsed.strokes)) return null;
        return parsed;
      } catch (error) {
        console.warn('No se pudo leer la cache local de Crea.', error);
        return null;
      }
    }

    function writeBoardCache(payload) {
      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify(payload));
      } catch (error) {
        console.warn('No se pudo guardar la cache local de Crea.', error);
      }
    }

    function isBoardEmpty(payload) {
      return !payload || !Array.isArray(payload.strokes) || payload.strokes.length === 0;
    }

    function applyBoardPayload(parsed) {
      if (!parsed || !Array.isArray(parsed.strokes)) return false;

      if (isHexColor(parsed.brushColor)) {
        state.brushColor = parsed.brushColor;
        colorInput.value = parsed.brushColor;
      }
      if (Number.isFinite(parsed.brushSize)) {
        state.brushSize = clamp(Number(parsed.brushSize), BRUSH_MIN, BRUSH_MAX);
      }
      if (Number.isFinite(parsed.eraserSize)) {
        state.eraserSize = clamp(Number(parsed.eraserSize), ERASER_MIN, ERASER_MAX);
      }

      const loadedStrokes = [];
      let loadedPoints = 0;
      const candidates = parsed.strokes.slice(-MAX_STROKES_TO_LOAD);
      for (const rawElement of candidates) {
        const element = sanitizeBoardElement(rawElement);
        if (!element) continue;
        if (element.mode !== 'image') {
          loadedPoints += element.points.length;
          if (loadedPoints > MAX_POINTS_TO_LOAD) break;
        }
        loadedStrokes.push(element);
      }

      state.strokes = loadedStrokes;
      state.selectedImageIndex = -1;
      state.boardUpdatedAt =
        typeof parsed.updatedAt === 'string' ? parsed.updatedAt : state.boardUpdatedAt;
      state.boardUpdatedBy =
        typeof parsed.updatedBy === 'string' ? parsed.updatedBy : state.boardUpdatedBy;
      hasPendingBoardChanges = false;
      updateSwatches();
      syncSizeUi();
      render();
      return true;
    }

    async function fetchSharedBoardSnapshot(silent = false) {
      try {
        const response = await fetch(`${apiBase}/crea/board`, { cache: 'no-store' });
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }
        return await response.json();
      } catch (error) {
        if (!silent) {
          console.warn('No se pudo cargar la pizarra compartida.', error);
        }
        return null;
      }
    }

    async function fetchSharedBoard(options = {}) {
      const { forceApply = false, silent = false } = options;
      if (!forceApply && (hasActiveInteraction() || saveTimer || isSavingBoard || hasPendingBoardChanges)) {
        return false;
      }

      const payload = await fetchSharedBoardSnapshot(silent);
      if (!payload) {
        return false;
      }

      const remoteUpdatedAt = typeof payload.updatedAt === 'string' ? payload.updatedAt : '';
      if (!forceApply && remoteUpdatedAt && remoteUpdatedAt === state.boardUpdatedAt) {
        return true;
      }

      const applied = applyBoardPayload(payload);
      if (applied) {
        writeBoardCache(payload);
      }
      return applied;
    }

    async function persistDrawingNow(options = {}) {
      const { keepalive = false, silent = false } = options;
      if (saveTimer) {
        window.clearTimeout(saveTimer);
        saveTimer = null;
      }

      const payload = buildBoardPayload();
      writeBoardCache({
        ...payload,
        updatedAt: state.boardUpdatedAt || new Date().toISOString(),
        updatedBy: state.boardUpdatedBy || '',
      });

      if (!state.canEdit || isSavingBoard) {
        return false;
      }

      const token = getEditorToken();
      if (!token) {
        return false;
      }

      isSavingBoard = true;
      try {
        const response = await fetch(`${apiBase}/crea/board`, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify(payload),
          keepalive,
        });
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }
        const savedPayload = await response.json();
        state.boardUpdatedAt =
          typeof savedPayload.updatedAt === 'string' ? savedPayload.updatedAt : state.boardUpdatedAt;
        state.boardUpdatedBy =
          typeof savedPayload.updatedBy === 'string' ? savedPayload.updatedBy : state.boardUpdatedBy;
        hasPendingBoardChanges = false;
        writeBoardCache({
          ...payload,
          updatedAt: state.boardUpdatedAt,
          updatedBy: state.boardUpdatedBy,
        });
        return true;
      } catch (error) {
        if (!silent) {
          console.warn('No se pudo guardar la pizarra compartida.', error);
        }
        return false;
      } finally {
        isSavingBoard = false;
      }
    }

    function schedulePersistDrawing() {
      hasPendingBoardChanges = true;
      if (saveTimer) window.clearTimeout(saveTimer);
      saveTimer = window.setTimeout(() => {
        saveTimer = null;
        void persistDrawingNow({ silent: true });
      }, SAVE_DEBOUNCE_MS);
    }

    function startBoardPolling() {
      if (boardPollTimer) {
        window.clearInterval(boardPollTimer);
      }
      boardPollTimer = window.setInterval(() => {
        if (document.hidden) return;
        void fetchSharedBoard({ silent: true });
      }, BOARD_POLL_INTERVAL_MS);
    }

    function isTextInput(target) {
      if (!(target instanceof HTMLElement)) return false;
      const tag = target.tagName;
      return tag === 'INPUT' || tag === 'TEXTAREA' || target.isContentEditable;
    }

    function clampCamera() {
      const halfVisibleW = state.viewportWidth / (2 * state.zoom);
      const halfVisibleH = state.viewportHeight / (2 * state.zoom);
      const minX = halfVisibleW;
      const maxX = world.width - halfVisibleW;
      const minY = halfVisibleH;
      const maxY = world.height - halfVisibleH;

      state.cameraX = minX <= maxX ? clamp(state.cameraX, minX, maxX) : world.width / 2;
      state.cameraY = minY <= maxY ? clamp(state.cameraY, minY, maxY) : world.height / 2;
    }

    function toWorldX(screenX) {
      return (screenX - state.viewportWidth / 2) / state.zoom + state.cameraX;
    }

    function toWorldY(screenY) {
      return (screenY - state.viewportHeight / 2) / state.zoom + state.cameraY;
    }

    function toScreenX(worldX) {
      return (worldX - state.cameraX) * state.zoom + state.viewportWidth / 2;
    }

    function toScreenY(worldY) {
      return (worldY - state.cameraY) * state.zoom + state.viewportHeight / 2;
    }

    function getPointerPosition(event) {
      const rect = canvas.getBoundingClientRect();
      return { x: event.clientX - rect.left, y: event.clientY - rect.top };
    }

    function clampPointToWorld(point) {
      return { x: clamp(point.x, 0, world.width), y: clamp(point.y, 0, world.height) };
    }

    function getWorldRectOnScreen() {
      const left = toScreenX(0);
      const top = toScreenY(0);
      const right = toScreenX(world.width);
      const bottom = toScreenY(world.height);
      return { x: left, y: top, width: right - left, height: bottom - top };
    }

    function updateCursor() {
      if (!state.canEdit) {
        canvas.style.cursor = state.isPanning ? 'grabbing' : 'grab';
        return;
      }

      if (state.resizeImagePointerId !== null) {
        canvas.style.cursor = 'nwse-resize';
        return;
      }

      if (state.dragImagePointerId !== null) {
        canvas.style.cursor = 'grabbing';
        return;
      }

      if (state.isPanning) {
        canvas.style.cursor = 'grabbing';
        return;
      }

      if (state.tool === 'select' && state.pointerInside) {
        const worldX = toWorldX(state.pointerX);
        const worldY = toWorldY(state.pointerY);
        const selectedImage = getSelectedImageElement();
        if (selectedImage && isPointInImageHandle(worldX, worldY, selectedImage)) {
          canvas.style.cursor = 'nwse-resize';
          return;
        }
        if (getImageIndexAtWorldPoint(worldX, worldY) !== -1) {
          canvas.style.cursor = 'move';
          return;
        }
        canvas.style.cursor = 'default';
        return;
      }

      if (state.tool === 'move' || state.spacePan) {
        canvas.style.cursor = 'grab';
        return;
      }
      if (state.tool === 'erase') {
        canvas.style.cursor = 'none';
        return;
      }
      canvas.style.cursor = 'crosshair';
    }

    function setButtonState(button, isActive) {
      button.classList.toggle('bg-utem-blue', isActive);
      button.classList.toggle('text-white', isActive);
      button.classList.toggle('border-utem-blue/70', isActive);
      button.classList.toggle('bg-white', !isActive);
      button.classList.toggle('text-utem-dark', !isActive);
      button.classList.toggle('border-utem-gray/70', !isActive);
    }

    function updateToolButtons() {
      setButtonState(drawButton, state.tool === 'draw');
      setButtonState(moveButton, state.tool === 'move');
      setButtonState(eraseButton, state.tool === 'erase');
      setButtonState(selectButton, state.tool === 'select');
    }

    function updateSwatches() {
      for (const swatch of swatches) {
        const swatchColor = swatch.getAttribute('data-color');
        const isActive = swatchColor?.toLowerCase() === state.brushColor.toLowerCase();
        swatch.classList.toggle('ring-2', Boolean(isActive));
        swatch.classList.toggle('ring-offset-1', Boolean(isActive));
        swatch.classList.toggle('ring-utem-blue', Boolean(isActive));
      }
    }

    function getToolSizeConfig(tool) {
      if (tool === 'erase') {
        return {
          label: 'Grosor Goma',
          value: state.eraserSize,
          min: ERASER_MIN,
          max: ERASER_MAX,
        };
      }

      return {
        label: 'Grosor Lapiz',
        value: state.brushSize,
        min: BRUSH_MIN,
        max: BRUSH_MAX,
      };
    }

    function applyToolSizeValue(tool, value) {
      if (tool === 'erase') {
        state.eraserSize = clamp(value, ERASER_MIN, ERASER_MAX);
        return;
      }
      state.brushSize = clamp(value, BRUSH_MIN, BRUSH_MAX);
    }

    function syncSizeUi() {
      const config = getToolSizeConfig(state.tool);
      sizeModeLabel.textContent = config.label;
      sizeInput.min = String(config.min);
      sizeInput.max = String(config.max);
      sizeInput.value = String(config.value);
      sizeValue.textContent = `${Math.round(config.value)}px`;
    }

    function setSizePanelOpen(open) {
      state.sizePanelOpen = open;
      sizePanel.classList.toggle('hidden', !open);
      sizeToggleSymbol.textContent = open ? '-' : '+';
    }

    function setTool(tool) {
      if (!state.canEdit && tool !== 'move') {
        return;
      }
      state.tool = tool;
      state.dragImagePointerId = null;
      state.resizeImagePointerId = null;
      activeTool.textContent = toolLabel(tool);
      updateToolButtons();
      syncSizeUi();
      updateCursor();
      render();
    }

    function setEditingState(canEdit, accountName = '') {
      state.canEdit = canEdit;
      readonlyNotice.classList.toggle('hidden', canEdit);
      accessLink.classList.toggle('hidden', canEdit);
      accessStatus.textContent = canEdit
        ? `Acceso habilitado${accountName ? ` para ${accountName}` : ''}. Ya puedes editar la pizarra compartida.`
        : 'Solo cuentas @utem.cl registradas pueden dibujar o pegar imagenes en esta pizarra compartida.';
      accessPanel.classList.toggle('border-utem-blue/30', !canEdit);
      accessPanel.classList.toggle('bg-utem-blue/5', !canEdit);
      accessPanel.classList.toggle('border-green-300', canEdit);
      accessPanel.classList.toggle('bg-green-50', canEdit);

      editControls.forEach((control) => {
        control.disabled = !canEdit;
        control.classList.toggle('opacity-50', !canEdit);
        control.classList.toggle('cursor-not-allowed', !canEdit);
      });

      if (!canEdit) {
        state.selectedImageIndex = -1;
        setTool('move');
      } else {
        setTool(state.tool === 'move' ? 'draw' : state.tool);
      }
    }

    function syncPageHeight() {
      const headerHeight = siteHeader ? Math.ceil(siteHeader.getBoundingClientRect().height) : 0;
      const targetHeight = Math.max(340, window.innerHeight - headerHeight);
      pageRoot.style.height = `${targetHeight}px`;
    }

    function fitCanvasToWrapper() {
      const bounds = canvasWrapper.getBoundingClientRect();
      const width = Math.max(240, Math.floor(bounds.width));
      const height = Math.max(240, Math.floor(bounds.height));
      state.viewportWidth = width;
      state.viewportHeight = height;
      state.dpr = window.devicePixelRatio || 1;
      canvas.width = Math.floor(width * state.dpr);
      canvas.height = Math.floor(height * state.dpr);
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      const minZoomByWidth = state.viewportWidth / world.width;
      const minZoomByHeight = state.viewportHeight / world.height;
      state.minZoom = Math.max(0.02, minZoomByWidth, minZoomByHeight);
      if (state.zoom < state.minZoom) {
        state.zoom = state.minZoom;
      }
      clampCamera();
      render();
    }

    function drawGrid() {
      const topLeft = { x: toWorldX(0), y: toWorldY(0) };
      const bottomRight = { x: toWorldX(state.viewportWidth), y: toWorldY(state.viewportHeight) };
      const step =
        state.zoom >= 6
          ? 50
          : state.zoom >= 3
            ? 100
            : state.zoom >= 1.5
              ? 200
              : state.zoom >= 0.8
                ? 400
                : state.zoom >= 0.35
                  ? 800
                  : 1600;

      const startX = Math.max(0, Math.floor(topLeft.x / step) * step);
      const endX = Math.min(world.width, Math.ceil(bottomRight.x / step) * step);
      const startY = Math.max(0, Math.floor(topLeft.y / step) * step);
      const endY = Math.min(world.height, Math.ceil(bottomRight.y / step) * step);

      context.beginPath();
      for (let x = startX; x <= endX; x += step) {
        const sx = toScreenX(x);
        context.moveTo(sx, 0);
        context.lineTo(sx, state.viewportHeight);
      }
      for (let y = startY; y <= endY; y += step) {
        const sy = toScreenY(y);
        context.moveTo(0, sy);
        context.lineTo(state.viewportWidth, sy);
      }
      context.strokeStyle = 'rgba(100, 116, 139, 0.32)';
      context.lineWidth = 1;
      context.stroke();
    }

    function drawRoundStroke(stroke) {
      context.strokeStyle = stroke.color;
      context.fillStyle = stroke.color;
      context.lineWidth = Math.max(1, stroke.size * state.zoom);
      context.lineJoin = 'round';
      context.lineCap = 'round';

      if (stroke.points.length === 1) {
        const point = stroke.points[0];
        context.beginPath();
        context.arc(
          toScreenX(point.x),
          toScreenY(point.y),
          Math.max(1, (stroke.size * state.zoom) / 2),
          0,
          Math.PI * 2
        );
        context.fill();
        return;
      }

      context.beginPath();
      context.moveTo(toScreenX(stroke.points[0].x), toScreenY(stroke.points[0].y));
      for (let i = 1; i < stroke.points.length; i += 1) {
        const point = stroke.points[i];
        context.lineTo(toScreenX(point.x), toScreenY(point.y));
      }
      context.stroke();
    }

    function drawSquareEraseStroke(stroke) {
      const pixelSize = Math.max(4, stroke.size * state.zoom);
      const half = pixelSize / 2;
      context.fillStyle = '#FFFFFF';

      if (stroke.points.length === 1) {
        const p = stroke.points[0];
        const sx = toScreenX(p.x);
        const sy = toScreenY(p.y);
        context.fillRect(sx - half, sy - half, pixelSize, pixelSize);
        return;
      }

      for (let i = 1; i < stroke.points.length; i += 1) {
        const p1 = stroke.points[i - 1];
        const p2 = stroke.points[i];
        const x1 = toScreenX(p1.x);
        const y1 = toScreenY(p1.y);
        const x2 = toScreenX(p2.x);
        const y2 = toScreenY(p2.y);
        const dx = x2 - x1;
        const dy = y2 - y1;
        const distance = Math.hypot(dx, dy);
        const steps = Math.max(1, Math.ceil(distance / Math.max(1, pixelSize * 0.35)));

        for (let step = 0; step <= steps; step += 1) {
          const t = step / steps;
          context.fillRect(x1 + dx * t - half, y1 + dy * t - half, pixelSize, pixelSize);
        }
      }
    }

    function getCachedImage(src) {
      let image = imageCache.get(src);
      if (!image) {
        image = new Image();
        image.src = src;
        imageCache.set(src, image);
      }
      return image;
    }

    function drawBoardImage(imageElement) {
      const image = getCachedImage(imageElement.src);
      if (!image.complete || image.naturalWidth === 0 || image.naturalHeight === 0) return;

      const x = toScreenX(imageElement.x);
      const y = toScreenY(imageElement.y);
      const width = imageElement.width * state.zoom;
      const height = imageElement.height * state.zoom;
      context.drawImage(image, x, y, width, height);
    }

    function fitImageDimensions(naturalWidth, naturalHeight) {
      const ratio = naturalWidth / naturalHeight;
      let width = naturalWidth;
      let height = naturalHeight;
      const largestSide = Math.max(width, height);

      if (largestSide > MAX_IMAGE_SIDE) {
        const scale = MAX_IMAGE_SIDE / largestSide;
        width *= scale;
        height *= scale;
      }

      if (Math.min(width, height) < MIN_IMAGE_SIDE) {
        if (ratio >= 1) {
          height = MIN_IMAGE_SIDE;
          width = height * ratio;
        } else {
          width = MIN_IMAGE_SIDE;
          height = width / ratio;
        }
      }

      return normalizeImagePlacement(0, 0, width, height);
    }

    function fileToDataUrl(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(String(reader.result || ''));
        reader.onerror = () => reject(new Error('No se pudo leer la imagen.'));
        reader.readAsDataURL(file);
      });
    }

    function addImageFromDataUrl(dataUrl, anchorX, anchorY) {
      if (typeof dataUrl !== 'string' || !dataUrl.startsWith('data:image/')) return;

      const image = new Image();
      image.onload = () => {
        const fitted = fitImageDimensions(image.naturalWidth, image.naturalHeight);
        const worldAnchorX = toWorldX(anchorX);
        const worldAnchorY = toWorldY(anchorY);
        const placement = normalizeImagePlacement(
          worldAnchorX - fitted.width / 2,
          worldAnchorY - fitted.height / 2,
          fitted.width,
          fitted.height
        );

        const imageElement = {
          mode: 'image',
          src: dataUrl,
          x: placement.x,
          y: placement.y,
          width: placement.width,
          height: placement.height,
        };

        state.strokes.push(imageElement);
        state.selectedImageIndex = state.strokes.length - 1;
        imageCache.set(dataUrl, image);
        schedulePersistDrawing();
        render();
      };

      image.src = dataUrl;
    }

    function drawStrokes() {
      for (const element of state.strokes) {
        if (element.mode === 'image') {
          drawBoardImage(element);
          continue;
        }

        if (!element.points?.length) continue;
        if (element.mode === 'erase') {
          drawSquareEraseStroke(element);
        } else {
          drawRoundStroke(element);
        }
      }
    }

    function drawEraserPreview() {
      if (state.tool !== 'erase' || !state.pointerInside || state.isPanning) return;
      const side = Math.max(8, state.eraserSize * state.zoom);
      const half = side / 2;

      context.save();
      context.setLineDash([6, 4]);
      context.lineWidth = 1.5;
      context.strokeStyle = 'rgba(15, 23, 42, 0.95)';
      context.fillStyle = 'rgba(255, 255, 255, 0.35)';
      context.fillRect(state.pointerX - half, state.pointerY - half, side, side);
      context.strokeRect(state.pointerX - half, state.pointerY - half, side, side);
      context.restore();
    }

    function drawSelectedImageOverlay() {
      const selectedImage = getSelectedImageElement();
      if (!selectedImage) return;

      const x = toScreenX(selectedImage.x);
      const y = toScreenY(selectedImage.y);
      const width = selectedImage.width * state.zoom;
      const height = selectedImage.height * state.zoom;
      const handleSize = IMAGE_HANDLE_SCREEN_SIZE;
      const handleX = x + width - handleSize;
      const handleY = y + height - handleSize;

      context.save();
      context.setLineDash([8, 6]);
      context.lineWidth = 1.5;
      context.strokeStyle = 'rgba(37, 99, 235, 0.95)';
      context.fillStyle = 'rgba(37, 99, 235, 0.08)';
      context.fillRect(x, y, width, height);
      context.strokeRect(x, y, width, height);
      context.setLineDash([]);
      context.fillStyle = '#2563EB';
      context.fillRect(handleX, handleY, handleSize, handleSize);
      context.strokeStyle = '#FFFFFF';
      context.lineWidth = 1.5;
      context.strokeRect(handleX + 0.75, handleY + 0.75, handleSize - 1.5, handleSize - 1.5);
      context.restore();
    }

    function render() {
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);

      context.fillStyle = '#D9E2EC';
      context.fillRect(0, 0, state.viewportWidth, state.viewportHeight);

      const worldRect = getWorldRectOnScreen();
      context.fillStyle = '#FFFFFF';
      context.fillRect(worldRect.x, worldRect.y, worldRect.width, worldRect.height);

      context.save();
      context.beginPath();
      context.rect(worldRect.x, worldRect.y, worldRect.width, worldRect.height);
      context.clip();
      drawStrokes();
      drawGrid();
      drawSelectedImageOverlay();
      drawEraserPreview();
      context.restore();

      context.strokeStyle = 'rgba(51, 65, 85, 0.75)';
      context.lineWidth = 2;
      context.strokeRect(worldRect.x, worldRect.y, worldRect.width, worldRect.height);

      const zoomPercent = Math.round(state.zoom * 100);
      zoomLevel.textContent = `${zoomPercent}%`;
      zoomSlider.value = String(clamp(zoomPercent, Number(zoomSlider.min), Number(zoomSlider.max)));
      activeTool.textContent = toolLabel(state.tool);
    }

    function applyZoom(nextZoom, anchorX, anchorY) {
      const targetZoom = clamp(nextZoom, state.minZoom, state.maxZoom);
      if (Math.abs(targetZoom - state.zoom) < 0.00001) return;

      const worldBefore = { x: toWorldX(anchorX), y: toWorldY(anchorY) };
      state.zoom = targetZoom;
      state.cameraX = worldBefore.x - (anchorX - state.viewportWidth / 2) / state.zoom;
      state.cameraY = worldBefore.y - (anchorY - state.viewportHeight / 2) / state.zoom;

      clampCamera();
      render();
    }

    function resetView() {
      state.zoom = initialZoom;
      state.cameraX = world.width / 2;
      state.cameraY = world.height / 2;
      clampCamera();
      render();
    }

    function handlePanelZoomInput(event) {
      const value = clamp(Number(event.target.value) || 100, state.minZoom * 100, state.maxZoom * 100);
      applyZoom(value / 100, state.viewportWidth / 2, state.viewportHeight / 2);
    }

    function getImageAnchorPoint() {
      if (state.pointerInside) {
        return { x: state.pointerX, y: state.pointerY };
      }
      return {
        x: state.viewportWidth / 2,
        y: state.viewportHeight / 2,
      };
    }

    async function addImagesFromFiles(files) {
      const imageFiles = Array.from(files).filter((file) => file.type.startsWith('image/'));
      if (!imageFiles.length) return;

      const anchor = getImageAnchorPoint();
      for (const file of imageFiles) {
        try {
          const dataUrl = await fileToDataUrl(file);
          addImageFromDataUrl(dataUrl, anchor.x, anchor.y);
        } catch (error) {
          console.warn('No se pudo agregar una imagen.', error);
        }
      }
    }

    async function handlePaste(event) {
      if (!state.canEdit) return;
      if (isTextInput(event.target)) return;
      const items = event.clipboardData?.items;
      if (!items || items.length === 0) return;

      const files = [];
      for (const item of items) {
        if (!item.type.startsWith('image/')) continue;
        const file = item.getAsFile();
        if (file) files.push(file);
      }

      if (!files.length) return;
      event.preventDefault();
      await addImagesFromFiles(files);
    }

    function handlePointerDown(event) {
      if (event.button > 2) return;

      const pointer = getPointerPosition(event);
      state.lastPointerX = pointer.x;
      state.lastPointerY = pointer.y;
      state.pointerX = pointer.x;
      state.pointerY = pointer.y;
      state.pointerInside = true;
      const worldPoint = clampPointToWorld({
        x: toWorldX(pointer.x),
        y: toWorldY(pointer.y),
      });
      const shouldPanByButton =
        state.spacePan ||
        event.button === 1 ||
        event.button === 2 ||
        (!state.canEdit && event.button === 0);

      if (shouldPanByButton) {
        state.isPanning = true;
        state.panPointerId = event.pointerId;
        canvas.setPointerCapture(event.pointerId);
        updateCursor();
        event.preventDefault();
        render();
        return;
      }

      if (!state.canEdit) return;

      if (state.tool === 'move' && event.button === 0) {
        state.isPanning = true;
        state.panPointerId = event.pointerId;
        canvas.setPointerCapture(event.pointerId);
        updateCursor();
        event.preventDefault();
        render();
        return;
      }

      if (state.tool === 'select' && event.button === 0) {
        const selectedImage = getSelectedImageElement();
        if (selectedImage && isPointInImageHandle(worldPoint.x, worldPoint.y, selectedImage)) {
          state.resizeImagePointerId = event.pointerId;
          state.resizeStartWorldX = worldPoint.x;
          state.resizeStartWorldY = worldPoint.y;
          state.resizeStartWidth = selectedImage.width;
          state.resizeStartHeight = selectedImage.height;
          canvas.setPointerCapture(event.pointerId);
          updateCursor();
          event.preventDefault();
          render();
          return;
        }

        const hitImageIndex = getImageIndexAtWorldPoint(worldPoint.x, worldPoint.y);
        if (hitImageIndex !== -1) {
          const frontIndex = bringImageElementToFront(hitImageIndex);
          state.selectedImageIndex = frontIndex;
          const imageElement = getSelectedImageElement();
          if (imageElement) {
            state.dragImagePointerId = event.pointerId;
            state.imageDragOffsetX = worldPoint.x - imageElement.x;
            state.imageDragOffsetY = worldPoint.y - imageElement.y;
            canvas.setPointerCapture(event.pointerId);
            updateCursor();
            event.preventDefault();
            render();
            return;
          }
        }

        state.selectedImageIndex = -1;
        updateCursor();
        event.preventDefault();
        render();
        return;
      }

      if (event.button !== 0) return;
      const point = worldPoint;

      const stroke = {
        mode: state.tool === 'erase' ? 'erase' : 'draw',
        color: state.tool === 'erase' ? '#FFFFFF' : state.brushColor,
        size: state.tool === 'erase' ? state.eraserSize : state.brushSize,
        points: [point],
      };

      state.strokes.push(stroke);
      state.activeStroke = stroke;
      state.drawPointerId = event.pointerId;
      canvas.setPointerCapture(event.pointerId);
      event.preventDefault();
      updateCursor();
      render();
    }

    function handlePointerMove(event) {
      const pointer = getPointerPosition(event);
      state.pointerX = pointer.x;
      state.pointerY = pointer.y;
      state.pointerInside = true;
      const worldPoint = clampPointToWorld({
        x: toWorldX(pointer.x),
        y: toWorldY(pointer.y),
      });

      if (state.resizeImagePointerId !== null && event.pointerId === state.resizeImagePointerId) {
        const selectedImage = getSelectedImageElement();
        if (!selectedImage) {
          state.resizeImagePointerId = null;
          updateCursor();
          render();
          return;
        }

        const deltaX = worldPoint.x - state.resizeStartWorldX;
        const deltaY = worldPoint.y - state.resizeStartWorldY;
        const target = normalizeImagePlacement(
          selectedImage.x,
          selectedImage.y,
          state.resizeStartWidth + deltaX,
          state.resizeStartHeight + deltaY
        );

        selectedImage.width = target.width;
        selectedImage.height = target.height;
        selectedImage.x = clamp(selectedImage.x, 0, Math.max(0, world.width - selectedImage.width));
        selectedImage.y = clamp(selectedImage.y, 0, Math.max(0, world.height - selectedImage.height));

        schedulePersistDrawing();
        updateCursor();
        render();
        return;
      }

      if (state.dragImagePointerId !== null && event.pointerId === state.dragImagePointerId) {
        const selectedImage = getSelectedImageElement();
        if (!selectedImage) {
          state.dragImagePointerId = null;
          updateCursor();
          render();
          return;
        }

        const targetX = worldPoint.x - state.imageDragOffsetX;
        const targetY = worldPoint.y - state.imageDragOffsetY;
        const target = normalizeImagePlacement(
          targetX,
          targetY,
          selectedImage.width,
          selectedImage.height
        );

        selectedImage.x = target.x;
        selectedImage.y = target.y;

        schedulePersistDrawing();
        updateCursor();
        render();
        return;
      }

      if (state.isPanning && event.pointerId === state.panPointerId) {
        const dx = pointer.x - state.lastPointerX;
        const dy = pointer.y - state.lastPointerY;

        state.cameraX -= dx / state.zoom;
        state.cameraY -= dy / state.zoom;
        state.lastPointerX = pointer.x;
        state.lastPointerY = pointer.y;

        clampCamera();
        render();
        return;
      }

      if (!state.activeStroke || event.pointerId !== state.drawPointerId) {
        updateCursor();
        if (state.tool === 'erase') render();
        return;
      }

      const point = worldPoint;

      const points = state.activeStroke.points;
      const previous = points[points.length - 1];
      const minDistance = 0.6 / state.zoom;
      const distance = Math.hypot(point.x - previous.x, point.y - previous.y);

      if (distance >= minDistance) {
        points.push(point);
        schedulePersistDrawing();
        updateCursor();
        render();
      }
    }

    function stopPointerAction(event) {
      if (event.pointerId === state.panPointerId) {
        state.isPanning = false;
        state.panPointerId = null;
      }

      if (event.pointerId === state.dragImagePointerId) {
        state.dragImagePointerId = null;
        schedulePersistDrawing();
      }

      if (event.pointerId === state.resizeImagePointerId) {
        state.resizeImagePointerId = null;
        schedulePersistDrawing();
      }

      if (event.pointerId === state.drawPointerId) {
        state.activeStroke = null;
        state.drawPointerId = null;
        schedulePersistDrawing();
      }

      if (canvas.hasPointerCapture(event.pointerId)) {
        canvas.releasePointerCapture(event.pointerId);
      }

      updateCursor();
      render();
    }

    function handleWheel(event) {
      event.preventDefault();
      const pointer = getPointerPosition(event);
      const factor = Math.exp(-event.deltaY * 0.0032);
      applyZoom(state.zoom * factor, pointer.x, pointer.y);
    }

    drawButton.addEventListener('click', () => setTool('draw'));
    moveButton.addEventListener('click', () => setTool('move'));
    eraseButton.addEventListener('click', () => setTool('erase'));
    selectButton.addEventListener('click', () => setTool('select'));

    colorInput.addEventListener('input', (event) => {
      state.brushColor = event.target.value;
      schedulePersistDrawing();
      updateSwatches();
    });

    for (const swatch of swatches) {
      swatch.addEventListener('click', () => {
        const selected = swatch.getAttribute('data-color');
        if (!selected) return;
        state.brushColor = selected;
        colorInput.value = selected;
        schedulePersistDrawing();
        updateSwatches();
      });
    }

    sizeInput.addEventListener('input', (event) => {
      const value = Number(event.target.value) || 1;
      applyToolSizeValue(state.tool, value);
      syncSizeUi();
      schedulePersistDrawing();
      render();
    });

    zoomInButton.addEventListener('click', () => {
      applyZoom(state.zoom * 1.35, state.viewportWidth / 2, state.viewportHeight / 2);
    });
    zoomOutButton.addEventListener('click', () => {
      applyZoom(state.zoom / 1.35, state.viewportWidth / 2, state.viewportHeight / 2);
    });
    zoomSlider.addEventListener('input', handlePanelZoomInput);

    for (const presetButton of zoomPresets) {
      presetButton.addEventListener('click', () => {
        const zoomPct = Number(presetButton.getAttribute('data-zoom'));
        if (!Number.isFinite(zoomPct)) return;
        applyZoom(zoomPct / 100, state.viewportWidth / 2, state.viewportHeight / 2);
      });
    }

    toggleSizePanelButton.addEventListener('click', () => {
      setSizePanelOpen(!state.sizePanelOpen);
    });

    resetViewButton.addEventListener('click', resetView);

    canvas.addEventListener('pointerdown', handlePointerDown);
    canvas.addEventListener('pointermove', handlePointerMove);
    canvas.addEventListener('pointerup', stopPointerAction);
    canvas.addEventListener('pointercancel', stopPointerAction);
    canvas.addEventListener('pointerenter', (event) => {
      const pointer = getPointerPosition(event);
      state.pointerX = pointer.x;
      state.pointerY = pointer.y;
      state.pointerInside = true;
      updateCursor();
      render();
    });
    canvas.addEventListener('pointerleave', () => {
      state.pointerInside = false;
      updateCursor();
      render();
    });
    canvas.addEventListener('wheel', handleWheel, { passive: false });
    canvas.addEventListener('contextmenu', (event) => event.preventDefault());

    window.addEventListener('resize', () => {
      syncPageHeight();
      fitCanvasToWrapper();
    });

    if (window.ResizeObserver && siteHeader) {
      const headerObserver = new ResizeObserver(() => {
        syncPageHeight();
        fitCanvasToWrapper();
      });
      headerObserver.observe(siteHeader);
    }

    window.addEventListener('keydown', (event) => {
      if (event.code !== 'Space' || isTextInput(event.target)) return;
      if (!state.spacePan) {
        state.spacePan = true;
        updateCursor();
      }
      event.preventDefault();
    });

    window.addEventListener('keyup', (event) => {
      if (event.code !== 'Space') return;
      state.spacePan = false;
      updateCursor();
    });

    window.addEventListener('beforeunload', () => {
      void persistDrawingNow({ keepalive: true, silent: true });
    });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        void persistDrawingNow({ silent: true });
        return;
      }
      void fetchSharedBoard({ silent: true });
    });
    window.addEventListener('paste', handlePaste);

    async function validateSession(token, endpoint) {
      if (!token) return null;
      try {
        const response = await fetch(`${apiBase}${endpoint}`, {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });
        if (!response.ok) return null;
        return await response.json();
      } catch (error) {
        return null;
      }
    }

    async function bootAccess() {
      const returnTo = `${window.location.pathname}${window.location.search}`;
      accessLink.href = `/login/?returnTo=${encodeURIComponent(returnTo)}`;

      const studentPayload = await validateSession(window.localStorage.getItem(studentTokenKey) || '', '/auth/me');
      if (studentPayload) {
        setEditingState(true, studentPayload.name || studentPayload.email || '');
        return;
      }
      if (window.localStorage.getItem(studentTokenKey)) {
        window.localStorage.removeItem(studentTokenKey);
      }

      const adminPayload = await validateSession(window.localStorage.getItem(adminTokenKey) || '', '/admin/me');
      if (adminPayload) {
        setEditingState(true, adminPayload.email || 'admin');
        return;
      }
      if (window.localStorage.getItem(adminTokenKey)) {
        window.localStorage.removeItem(adminTokenKey);
      }

      setEditingState(false);
    }

    async function initializeBoardPage() {
      const cachedPayload = readBoardCachePayload();
      if (cachedPayload) {
        applyBoardPayload(cachedPayload);
      }
      setSizePanelOpen(false);
      setTool('move');
      updateSwatches();
      syncPageHeight();
      fitCanvasToWrapper();
      updateCursor();
      const remotePayload = await fetchSharedBoardSnapshot(true);
      if (remotePayload && !isBoardEmpty(remotePayload)) {
        applyBoardPayload(remotePayload);
        writeBoardCache(remotePayload);
      } else if (cachedPayload && !isBoardEmpty(cachedPayload)) {
        applyBoardPayload(cachedPayload);
      }
      await bootAccess();
      if (
        state.canEdit &&
        cachedPayload &&
        !isBoardEmpty(cachedPayload) &&
        (!remotePayload || isBoardEmpty(remotePayload))
      ) {
        hasPendingBoardChanges = true;
        void persistDrawingNow({ silent: true });
      }
      startBoardPolling();
    }

    void initializeBoardPage();
  </script>
</MainLayout>
