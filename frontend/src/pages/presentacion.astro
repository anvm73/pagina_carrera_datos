---
import MainLayout from '../layouts/MainLayout.astro';
import '../styles/global.css';

const apiBase = (import.meta.env.PUBLIC_PROJECTS_API_URL || '/api').replace(/\/$/, '');
---

<MainLayout>
  <div class="space-y-8 animate-fade-in">
    <header class="relative overflow-hidden rounded-2xl border border-utem-gray/50 bg-gradient-to-r from-utem-blueDark via-utem-blue to-utem-purple p-8 md:p-10 shadow-glow">
      <div class="relative z-10 space-y-4 text-center md:text-left">
        <p class="text-sm font-bold uppercase tracking-wider text-white/90">Presentacion</p>
        <h1 id="presentation-title" class="text-4xl md:text-5xl font-bold text-white leading-tight">
          Cargando presentaciones...
        </h1>
        <p id="presentation-description" class="text-lg text-white/90 max-w-3xl">
          El listado de PDFs se administra desde esta misma seccion cuando el modo admin esta activo.
        </p>
      </div>
    </header>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,320px)_minmax(0,1fr)]">
      <aside class="min-w-0 rounded-2xl border border-utem-gray/50 bg-white p-5 shadow-subtle">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold text-utem-dark">Presentaciones</h2>
          <button
            id="reload-presentations"
            type="button"
            class="rounded-lg border border-utem-gray/50 px-4 py-2 text-sm font-semibold text-utem-dark transition-colors hover:border-utem-blue hover:text-utem-blue"
          >
            Actualizar
          </button>
        </div>
        <div id="presentation-list" class="mt-4 flex flex-col gap-3">
          <p class="text-sm text-utem-dark/70">Cargando documentos...</p>
        </div>

        <form id="presentation-create-form" class="mt-5 hidden min-w-0 overflow-hidden rounded-2xl border border-dashed border-utem-blue/30 bg-utem-blue/5 p-4">
          <p class="text-sm font-bold uppercase tracking-wide text-utem-blue">Agregar PDF</p>
          <div class="grid gap-3">
            <input name="title" type="text" class="min-w-0 w-full rounded-xl border border-utem-gray/60 px-4 py-3 text-sm focus:border-utem-blue focus:outline-none" placeholder="Titulo" />
            <textarea name="description" rows="3" class="min-w-0 w-full rounded-xl border border-utem-gray/60 px-4 py-3 text-sm focus:border-utem-blue focus:outline-none" placeholder="Descripcion"></textarea>
            <input name="pdf" type="file" accept="application/pdf" required class="min-w-0 w-full rounded-xl border border-utem-gray/60 px-4 py-3 text-sm file:mr-3 file:rounded-md file:border-0 file:bg-utem-blue/10 file:px-3 file:py-1 file:text-utem-blue" />
            <button type="submit" class="w-full rounded-full bg-gradient-utem px-4 py-2 text-sm font-bold text-white">Subir presentacion</button>
          </div>
        </form>
      </aside>

      <section id="presentation-shell" class="min-w-0 rounded-2xl border border-utem-gray/50 bg-white p-4 md:p-6 shadow-subtle">
        <div id="presentation-controls" class="flex flex-wrap items-center justify-between gap-3 border-b border-utem-gray/40 pb-4">
          <div id="slide-nav-controls" class="flex items-center gap-2">
            <button
              id="prev-slide"
              type="button"
              class="rounded-lg border border-utem-gray/50 px-4 py-2 text-sm font-semibold text-utem-dark transition-colors hover:border-utem-blue hover:text-utem-blue disabled:cursor-not-allowed disabled:opacity-50"
            >
              Anterior
            </button>
            <button
              id="next-slide"
              type="button"
              class="rounded-lg border border-utem-gray/50 px-4 py-2 text-sm font-semibold text-utem-dark transition-colors hover:border-utem-blue hover:text-utem-blue disabled:cursor-not-allowed disabled:opacity-50"
            >
              Siguiente
            </button>
          </div>

          <div id="slide-page-indicator" class="flex items-center gap-2 text-sm font-medium text-utem-dark">
            <label for="slide-number">Slide</label>
            <input
              id="slide-number"
              type="number"
              min="1"
              value="1"
              class="w-16 rounded-md border border-utem-gray/60 px-2 py-1 text-center focus:border-utem-blue focus:outline-none"
            />
            <span id="slide-total">/ -</span>
          </div>

          <div id="action-controls" class="flex flex-wrap items-center gap-2">
            <button
              id="fullscreen-toggle"
              type="button"
              class="rounded-lg border border-utem-gray/50 px-4 py-2 text-sm font-bold text-utem-dark transition-colors hover:border-utem-blue hover:text-utem-blue"
            >
              Pantalla completa
            </button>
            <a
              id="open-pdf-link"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg bg-gradient-utem px-4 py-2 text-sm font-bold text-white transition-all hover:shadow-glowBlue"
            >
              Abrir PDF
            </a>
          </div>
        </div>

        <div id="slide-stage" class="mt-5 flex h-[60vh] min-h-[420px] items-center justify-center overflow-auto rounded-2xl bg-slate-950 p-4 md:p-6">
          <canvas id="slide-canvas" class="max-h-full max-w-full rounded-lg shadow-2xl"></canvas>
        </div>

        <p id="viewer-status" class="mt-4 text-sm text-utem-dark/80">Cargando presentacion...</p>
        <noscript>
          <p class="mt-4 text-sm text-utem-dark/80">
            Activa JavaScript para usar la vista por slide.
          </p>
        </noscript>
      </section>
    </section>
  </div>
</MainLayout>

<style>
  #presentation-shell:fullscreen {
    width: 100vw;
    height: 100vh;
    border-radius: 0;
    border: 0;
    margin: 0;
    padding: 1rem;
    background: #020617;
    display: flex;
    flex-direction: column;
  }

  #presentation-shell:fullscreen #presentation-controls {
    border-color: rgba(255, 255, 255, 0.2);
    justify-content: flex-end;
  }

  #presentation-shell:fullscreen #slide-stage {
    flex: 1;
    min-height: 0;
    height: auto;
  }

  #presentation-shell:fullscreen #slide-nav-controls,
  #presentation-shell:fullscreen #slide-page-indicator,
  #presentation-shell:fullscreen #open-pdf-link {
    display: none;
  }
</style>

<script is:inline define:vars={{ apiBase }}>
  window.CE_API_BASE = apiBase;
</script>

<script type="module">
  import {
    escapeHtml,
    isAdminSession,
    requestJson,
    resolveAssetUrl,
  } from '/admin-client.js';

  const { getDocument, GlobalWorkerOptions } = await import('https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.min.mjs');
  GlobalWorkerOptions.workerSrc = 'https://cdn.jsdelivr.net/npm/pdfjs-dist@4.10.38/build/pdf.worker.min.mjs';

  const apiBase = window.CE_API_BASE || '/api';
  const titleEl = document.getElementById('presentation-title');
  const descriptionEl = document.getElementById('presentation-description');
  const listEl = document.getElementById('presentation-list');
  const createFormEl = document.getElementById('presentation-create-form');
  const shellEl = document.getElementById('presentation-shell');
  const stageEl = document.getElementById('slide-stage');
  const canvasEl = document.getElementById('slide-canvas');
  const statusEl = document.getElementById('viewer-status');
  const prevBtn = document.getElementById('prev-slide');
  const nextBtn = document.getElementById('next-slide');
  const pageInputEl = document.getElementById('slide-number');
  const totalEl = document.getElementById('slide-total');
  const fullscreenBtn = document.getElementById('fullscreen-toggle');
  const openLinkEl = document.getElementById('open-pdf-link');
  const reloadBtn = document.getElementById('reload-presentations');

  if (
    !titleEl ||
    !descriptionEl ||
    !listEl ||
    !createFormEl ||
    !shellEl ||
    !stageEl ||
    !canvasEl ||
    !statusEl ||
    !prevBtn ||
    !nextBtn ||
    !pageInputEl ||
    !totalEl ||
    !fullscreenBtn ||
    !openLinkEl ||
    !reloadBtn
  ) {
    throw new Error('No se encontraron los elementos del visor de presentaciones.');
  }

  const context = canvasEl.getContext('2d');
  if (!context) {
    throw new Error('Canvas 2D no disponible.');
  }

  let adminMode = false;
  let presentations = [];
  let activeId = '';
  let pdfDocument = null;
  let currentPage = 1;
  let totalPages = 0;
  let rendering = false;
  let loadingDocument = false;

  const resolvePdfUrl = (url) => resolveAssetUrl(url, apiBase) || '#';

  const updateControls = () => {
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;
    pageInputEl.value = String(currentPage);
    pageInputEl.max = String(totalPages || 1);
    totalEl.textContent = `/ ${totalPages || '-'}`;
  };

  const renderPage = async (pageNumber) => {
    if (!pdfDocument || rendering) return;

    rendering = true;
    statusEl.textContent = `Mostrando slide ${pageNumber} de ${totalPages}`;

    try {
      const page = await pdfDocument.getPage(pageNumber);
      const baseViewport = page.getViewport({ scale: 1 });
      const maxWidth = Math.max(stageEl.clientWidth - 32, 320);
      const maxHeight = Math.max(stageEl.clientHeight - 32, 320);
      const fitScale = Math.min(maxWidth / baseViewport.width, maxHeight / baseViewport.height);
      const outputScale = window.devicePixelRatio || 1;
      const viewport = page.getViewport({ scale: fitScale });

      canvasEl.width = Math.floor(viewport.width * outputScale);
      canvasEl.height = Math.floor(viewport.height * outputScale);
      canvasEl.style.width = `${Math.floor(viewport.width)}px`;
      canvasEl.style.height = `${Math.floor(viewport.height)}px`;

      await page.render({
        canvasContext: context,
        viewport,
        transform: outputScale !== 1 ? [outputScale, 0, 0, outputScale, 0, 0] : null,
      }).promise;

      currentPage = pageNumber;
      updateControls();
    } catch (error) {
      console.error(error);
      statusEl.textContent = 'Error al renderizar la presentacion. Usa "Abrir PDF".';
    } finally {
      rendering = false;
    }
  };

  const goToPage = (nextPage) => {
    if (!totalPages || loadingDocument) return;
    const parsed = Number(nextPage);
    if (Number.isNaN(parsed)) return;
    const safePage = Math.min(Math.max(parsed, 1), totalPages);
    renderPage(safePage);
  };

  const renderList = () => {
    if (!presentations.length) {
      listEl.innerHTML = '<p class="text-sm text-utem-dark/70">No hay presentaciones publicadas.</p>';
      titleEl.textContent = 'No hay presentaciones';
      descriptionEl.textContent = 'Sube PDF desde esta misma seccion para que aparezcan aqui.';
      statusEl.textContent = 'Sin contenido disponible.';
      openLinkEl.href = '#';
      pdfDocument = null;
      return;
    }

    listEl.innerHTML = presentations
      .map((item) => {
        const active = item.id === activeId;
        return `
          <div data-presentation-id="${escapeHtml(item.id)}" class="rounded-xl border px-4 py-3 text-left transition-all ${
            active
              ? 'border-utem-blue bg-utem-blue/5 text-utem-blueDark'
              : 'border-utem-gray/50 bg-white text-utem-dark hover:border-utem-blue/50 hover:bg-utem-blue/5'
          }">
            <button type="button" data-action="select-presentation" class="w-full text-left">
              <p class="text-base font-bold">${escapeHtml(item.title || 'Presentacion')}</p>
              <p class="mt-1 text-sm opacity-80">${escapeHtml(item.description || '')}</p>
            </button>
            ${adminMode ? '<button data-action="delete-presentation" type="button" class="mt-3 rounded-full border border-red-300 px-4 py-2 text-xs font-bold text-red-600">Eliminar</button>' : ''}
          </div>
        `;
      })
      .join('');
  };

  const loadDocument = async (item) => {
    if (!item) return;
    activeId = item.id;
    titleEl.textContent = item.title || 'Presentacion';
    descriptionEl.textContent = item.description || 'Documento PDF disponible para presentacion.';
    const pdfUrl = resolvePdfUrl(item.pdf_url || '');
    openLinkEl.href = pdfUrl;
    renderList();

    loadingDocument = true;
    statusEl.textContent = 'Cargando presentacion...';
    prevBtn.disabled = true;
    nextBtn.disabled = true;
    pageInputEl.disabled = true;

    try {
      const loadingTask = getDocument(pdfUrl);
      pdfDocument = await loadingTask.promise;
      totalPages = pdfDocument.numPages;
      currentPage = 1;
      pageInputEl.disabled = false;
      updateControls();
      await renderPage(1);
    } catch (error) {
      console.error(error);
      statusEl.textContent = 'No se pudo cargar la presentacion. Usa "Abrir PDF".';
      pdfDocument = null;
      totalPages = 0;
      currentPage = 1;
      updateControls();
    } finally {
      loadingDocument = false;
    }
  };

  const loadPresentations = async () => {
    listEl.innerHTML = '<p class="text-sm text-utem-dark/70">Cargando documentos...</p>';
    try {
      const response = await fetch(`${apiBase}/content/presentations`);
      if (!response.ok) throw new Error('No se pudo cargar el listado');
      const data = await response.json();
      presentations = Array.isArray(data.items) ? data.items : [];
      activeId = presentations[0]?.id || '';
      renderList();
      if (presentations[0]) {
        await loadDocument(presentations[0]);
      }
    } catch (error) {
      listEl.innerHTML = '<p class="text-sm text-red-600">No fue posible cargar las presentaciones.</p>';
      statusEl.textContent = 'Error al consultar el servidor.';
      openLinkEl.href = '#';
    }
  };

  createFormEl.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!adminMode) return;

    try {
      await requestJson('/admin/presentations', {
        method: 'POST',
        body: new FormData(createFormEl),
      }, apiBase);
      createFormEl.reset();
      await loadPresentations();
    } catch (error) {
      window.alert(error.message || 'No fue posible subir la presentacion.');
    }
  });

  listEl.addEventListener('click', async (event) => {
    const actionButton = event.target.closest('button[data-action]');
    if (!actionButton) return;

    const wrapper = actionButton.closest('[data-presentation-id]');
    if (!wrapper) return;
    const item = presentations.find((entry) => entry.id === wrapper.dataset.presentationId);
    if (!item) return;

    if (actionButton.dataset.action === 'select-presentation') {
      await loadDocument(item);
      return;
    }

    if (adminMode && actionButton.dataset.action === 'delete-presentation') {
      if (!window.confirm('Se eliminara esta presentacion. Deseas continuar?')) return;

      try {
        await requestJson(`/admin/presentations/${item.id}`, { method: 'DELETE' }, apiBase);
        await loadPresentations();
      } catch (error) {
        window.alert(error.message || 'No fue posible eliminar la presentacion.');
      }
    }
  });

  prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
  nextBtn.addEventListener('click', () => goToPage(currentPage + 1));
  stageEl.addEventListener('click', (event) => {
    const rect = stageEl.getBoundingClientRect();
    const middle = rect.left + rect.width / 2;
    if (event.clientX < middle) goToPage(currentPage - 1);
    else goToPage(currentPage + 1);
  });
  pageInputEl.addEventListener('change', () => goToPage(pageInputEl.value));
  pageInputEl.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      goToPage(pageInputEl.value);
    }
  });
  reloadBtn.addEventListener('click', loadPresentations);

  fullscreenBtn.addEventListener('click', async () => {
    try {
      if (document.fullscreenElement) {
        await document.exitFullscreen();
      } else {
        await shellEl.requestFullscreen();
      }
    } catch (error) {
      console.error(error);
    }
  });

  document.addEventListener('fullscreenchange', () => {
    fullscreenBtn.textContent = document.fullscreenElement ? 'Salir pantalla completa' : 'Pantalla completa';
    if (pdfDocument) {
      goToPage(currentPage);
    }
  });

  window.addEventListener('resize', () => {
    if (pdfDocument) {
      goToPage(currentPage);
    }
  });

  adminMode = await isAdminSession(apiBase);
  createFormEl.classList.toggle('hidden', !adminMode);
  await loadPresentations();
</script>
